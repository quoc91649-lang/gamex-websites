  <property name="styleSheet">
   <string notr="true">/* ===== MAIN WINDOW ===== */
QMainWindow {
    background-color: #181a24;
}

/* ===== LABEL ===== */
QLabel {
    color: #e6e6e6;
    font-size: 13px;
}

/* ===== PUSH BUTTON ===== */
QPushButton {
    background-color: #2979ff;   /* nền xanh */
   color: qlineargradient(
        spread:pad, x1:0, y1:0, x2:1, y2:0,
        stop:0 #ff0000,
        stop:0.2 #ff7f00,
        stop:0.4 #ffff00,
        stop:0.6 #00ff00,
        stop:0.8 #00bfff,
        stop:1 #8b00ff
    );

    border-radius: 12px;
    padding: 6px 14px;
    font-size: 12px;
    font-weight: bold;

    /* Rainbow border (ổn định Qt5/Qt6) */
    border: 2px solid qlineargradient(
        spread:pad, x1:0, y1:0, x2:1, y2:1,
        stop:0 #ff0000,
        stop:0.2 #ff7f00,
        stop:0.4 #ffff00,
        stop:0.6 #00ff00,
        stop:0.8 #00bfff,
        stop:1 #8b00ff
    );
}

/* Hover */
QPushButton:hover {
    background-color: #448aff;   /* sáng hơn */
}

/* Pressed */
QPushButton:pressed {
    background-color: #1c54b2;   /* đậm lại */
    padding-top: 8px;
    padding-bottom: 4px;
}

/* Disabled */
QPushButton:disabled {
    background-color: #555;
    color: #aaa;
    border: 2px solid #444;
}

/* ===== LIST WIDGET ===== */
QListWidget {
    background-color: #222436;
    border-radius: 10px;
    border: 2px solid qlineargradient(
        spread:pad, x1:0, y1:0, x2:1, y2:1,
        stop:0 #ff0000,
        stop:0.2 #ff7f00,
        stop:0.4 #ffff00,
        stop:0.6 #00ff00,
        stop:0.8 #00bfff,
        stop:1 #8b00ff
    );
    color: #e6e6e6;
    padding: 5px;
}

/* Item */
QListWidget::item {
    padding: 6px;
    border-radius: 6px;
}

/* Hover item */
QListWidget::item:hover {
    background-color: #2f3250;
}

/* Selected item */
QListWidget::item:selected {
    background-color: #2979ff;
    color: white;
}

/* ===== SCROLLBAR ===== */
QScrollBar:vertical {
    background: transparent;
    width: 8px;
}

QScrollBar::handle:vertical {
    background: #555;
    border-radius: 4px;
}

QScrollBar::handle:vertical:hover {
    background: #777;
}

QScrollBar::add-line,
QScrollBar::sub-line {
    height: 0;
}</string>
